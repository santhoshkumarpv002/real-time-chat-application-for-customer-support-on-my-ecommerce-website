{
  "name": "support-chat-backend",
  "version": "1.0.0",
  "description": "Real-time customer support chat backend",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name init",
    "db:seed": "node src/prisma/seed.js",
    "prisma:generate": "npx prisma generate --schema=src/prisma/schema.prisma",
    "prisma:push": "npx prisma db push --schema=src/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma": "5.22.0"
  }
}
